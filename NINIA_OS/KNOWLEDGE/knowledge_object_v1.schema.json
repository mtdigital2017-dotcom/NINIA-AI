{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ninia.local/schemas/knowledge-object-v1.schema.json",
  "title": "NINIA Knowledge Object v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "knowledge_id",
    "title",
    "content",
    "source",
    "evidence_status",
    "provenance",
    "created_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "knowledge_id": {
      "type": "string",
      "minLength": 8
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": [
        "string",
        "null"
      ]
    },
    "content": {
      "type": [
        "string",
        "object",
        "array"
      ]
    },
    "document_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "source_url_or_doi": {
      "type": [
        "string",
        "null"
      ]
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publication_year": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 1800,
      "maximum": 2100
    },
    "language": {
      "type": [
        "string",
        "null"
      ]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "evidence_level": {
      "type": [
        "string",
        "null"
      ]
    },
    "evidence_status": {
      "type": "string",
      "enum": [
        "PROPUESTO",
        "EN_VALIDACION",
        "APROBADO",
        "RECHAZADO"
      ]
    },
    "relation_to_ninia": {
      "type": [
        "string",
        "null"
      ]
    },
    "specialty": {
      "type": [
        "string",
        "null"
      ]
    },
    "provenance": {
      "type": "object",
      "required": [
        "source_path",
        "sha256"
      ],
      "properties": {
        "source_path": {
          "type": "string"
        },
        "sha256": {
          "type": "string",
          "minLength": 64,
          "maxLength": 64
        },
        "ingestion_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "validated_by": {
          "type": [
            "string",
            "null"
          ]
        },
        "validated_at": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "created_at": {
      "type": "string"
    },
    "updated_at": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
